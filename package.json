{
  "name": "shift-evidence",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "deploy:check": "node scripts/check-hostinger-env.mjs",
    "storage:check": "node scripts/check-storage-runtime.mjs",
    "hostinger:diagnose": "node scripts/hostinger-diagnose.mjs",
    "ai:guardrails": "node scripts/ai-advisory-guardrails-smoke.mjs",
    "ai:fallback-drill": "node scripts/ai-advisory-fallback-drill.mjs",
    "ai:smoke-local-gemini": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/smoke-local-gemini.mjs",
    "ai:report-synthetic": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/generate-full-synthetic-gemini-report.mjs",
    "ai:report-synthetic:require-gemini": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/generate-full-synthetic-gemini-report.mjs --require-real-gemini --output-dir=qa-artifacts/ai-report-1b",
    "sample-report:generate": "node scripts/generate-public-sample-report.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.11",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@types/pdfkit": "^0.17.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.11",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prisma": "^6.19.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  }
