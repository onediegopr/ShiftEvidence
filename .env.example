DATABASE_URL=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_TAG_ID=
NEXT_PUBLIC_GOOGLE_ADS_START_ASSESSMENT_SEND_TO=
NEXT_PUBLIC_GOOGLE_ADS_START_ASSESSMENT_VALUE=1.0
NEXT_PUBLIC_GOOGLE_ADS_START_ASSESSMENT_CURRENCY=ARS
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Explicit preview origins allowed for auth/checkout smoke.
# Comma-separated. Do not use wildcards.
PREVIEW_TRUSTED_ORIGINS=

ADMIN_EMAILS=
STORAGE_DRIVER=local
HOSTINGER_STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=50
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Preview-only fallback for controlled Vercel smoke when Upstash is not configured.
# Set to "memory" only in Vercel Preview, never Production.
RATE_LIMIT_PREVIEW_FALLBACK=

# Cloudflare R2 storage adapter
R2_ACCOUNT_ID=
R2_S3_ENDPOINT=
R2_BUCKET_PREVIEW=
R2_BUCKET_PROD=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
