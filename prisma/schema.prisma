generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id
  name                  String
  email                 String
  emailVerified         Boolean                @default(false)
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  sessions              Session[]
  accounts              Account[]
  profiles              UserProfile[]
  ownedWorkspaces       Workspace[]
  memberships           WorkspaceMember[]
  evidenceFiles         EvidenceFile[]
  auditEvents           AuditEvent[]
  aiUsageEvents         AiUsageEvent[]
  userEntitlements      UserEntitlement[]
  upgradeEvents         UpgradeEvent[]
  reports               Report[]
  unlockRequests        UnlockRequest[]
  createdAdvisorConversations AssessmentAdvisorConversation[] @relation("AssessmentAdvisorConversationCreatedBy")
  advisorMessages       AssessmentAdvisorMessage[] @relation("AssessmentAdvisorMessageUser")
  createdAdvisorMemoryItems AssessmentAdvisorMemoryItem[] @relation("AssessmentAdvisorMemoryItemCreatedBy")
  passwordResetRequests PasswordResetRequest[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model PasswordResetRequest {
  id              String    @id @default(cuid())
  userId          String?
  emailNormalized String
  emailHash       String
  tokenHash       String?   @unique
  status          String    @default("pending")
  deliveryMode    String    @default("manual")
  expiresAt       DateTime?
  usedAt          DateTime?
  requestedIpHash String?
  userAgentHash   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([emailHash])
  @@index([status])
  @@index([expiresAt])
}

model UserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  email         String   @unique
  name          String?
  imageUrl      String?
  authProvider  String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model Workspace {
  id             String            @id @default(cuid())
  ownerUserId    String
  name           String
  companyName    String?
  plan           WorkspacePlan     @default(free)
  billingStatus  BillingStatus     @default(none)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  ownerUser      User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  members        WorkspaceMember[]
  assessments    Assessment[]
  evidenceFiles  EvidenceFile[]
  auditEvents    AuditEvent[]
  upgradeEvents  UpgradeEvent[]
  reports        Report[]
  unlockRequests UnlockRequest[]
  advisorConversations AssessmentAdvisorConversation[]
  advisorMessages      AssessmentAdvisorMessage[]
  advisorMemoryItems   AssessmentAdvisorMemoryItem[]

  @@index([ownerUserId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(member)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Assessment {
  id                          String                                 @id @default(cuid())
  workspaceId                 String
  title                       String
  clientLabel                 String?
  assessmentType              AssessmentType                         @default(vmware_to_proxmox)
  sourcePlatform              SourcePlatform                         @default(vmware)
  targetPlatform              TargetPlatform                         @default(proxmox)
  status                      AssessmentStatus                       @default(draft)
  planLevel                   PlanLevel                              @default(free)
  storageReadinessEnabled     Boolean                                @default(false)
  storageReadinessStatus      StorageReadinessStatus                 @default(not_selected)
  archivedAt                  DateTime?
  createdAt                   DateTime                               @default(now())
  updatedAt                   DateTime                               @updatedAt
  workspace                   Workspace                              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  modules                     AssessmentModule[]
  infrastructureInput         AssessmentInfrastructureInput?
  costRiskAssumptions         CostRiskAssumptions?
  preliminaryResult           AssessmentPreliminaryResult?
  licensingAnalysis           AssessmentLicensingAnalysis?
  storageReadinessInput       StorageReadinessInput?
  storageDestinationReadiness AssessmentStorageDestinationReadiness?
  storageContext              AssessmentStorageContext?
  storageAnalysis             AssessmentStorageAnalysis?
  clientContext               AssessmentClientContext?
  clientContextAnalysis       AssessmentClientContextAnalysis?
  entitlements                AssessmentEntitlement[]
  evidenceFiles               EvidenceFile[]
  additionalEvidence          AssessmentAdditionalEvidence[]
  storageEvidence             AssessmentStorageEvidence[]
  parsedVMs                   ParsedVM[]
  parsedHosts                 ParsedHost[]
  parsedDatastores            ParsedDatastore[]
  parsedSnapshots             ParsedSnapshot[]
  parsedInventorySummaries    ParsedInventorySummary[]
  riskFindings                RiskFinding[]
  assessmentScore             AssessmentScore?
  auditEvents                 AuditEvent[]
  aiUsageEvents               AiUsageEvent[]
  upgradeEvents               UpgradeEvent[]
  reports                     Report[]
  unlockRequests              UnlockRequest[]
  advisorConversation         AssessmentAdvisorConversation?
  advisorMessages             AssessmentAdvisorMessage[]
  advisorMemoryItems          AssessmentAdvisorMemoryItem[]

  @@index([workspaceId])
  @@index([workspaceId, archivedAt, updatedAt])
  @@index([archivedAt, updatedAt])
  @@index([status])
}

model AssessmentModule {
  id             String                 @id @default(cuid())
  assessmentId   String
  moduleKey      AssessmentModuleKey
  status         AssessmentModuleStatus @default(locked)
  includedInPlan Boolean                @default(false)
  isOptional     Boolean                @default(false)
  isPaidAddon    Boolean                @default(false)
  priceCents     Int?
  currency       String                 @default("USD")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  assessment     Assessment             @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, moduleKey])
  @@index([assessmentId])
}

model CostRiskAssumptions {
  id                   String     @id @default(cuid())
  assessmentId         String     @unique
  vmwareLicenseModel   String?
  socketCount          Int?
  coreCount            Int?
  vmCount              Int?
  annualVmwareCost     Decimal?   @db.Decimal(14, 2)
  estimatedProxmoxCost Decimal?   @db.Decimal(14, 2)
  currency             String     @default("USD")
  years                Int        @default(3)
  migrationComplexity  String?
  businessCriticality  String?
  riskTolerance        String?
  assumptionsJson      Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  assessment           Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentInfrastructureInput {
  id                    String     @id @default(cuid())
  assessmentId          String     @unique
  vmCount               Int?
  hostCount             Int?
  clusterCount          Int?
  socketCount           Int?
  coreCount             Int?
  totalRamGb            Float?
  storageFootprintTb    Float?
  usedStorageTb         Float?
  snapshotCount         Int?
  criticalWorkloadCount Int?
  largeVmCount          Int?
  poweredOffVmCount     Int?
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  assessment            Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentPreliminaryResult {
  id                         String     @id @default(cuid())
  assessmentId               String     @unique
  annualSubscriptionDelta    Float?
  threeYearSubscriptionDelta Float?
  savingsPercent             Float?
  riskScore                  Int?
  riskLevel                  RiskLevel?
  readinessLabel             String?
  missingEvidenceJson        Json?
  recommendationsJson        Json?
  calculatedAt               DateTime?
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt
  assessment                 Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentLicensingAnalysis {
  id                       String                            @id @default(cuid())
  assessmentId             String                            @unique
  status                   AssessmentLicensingAnalysisStatus @default(not_included)
  mode                     AssessmentLicensingAnalysisMode   @default(skipped)
  currency                 String                            @default("USD")
  financialConfidenceScore Int?
  financialConfidenceLabel String?
  savingsQuality           String?
  pricingFreshnessStatus   String?
  vmwareScenarioJson       Json?
  proxmoxScenarioJson      Json?
  comparisonJson           Json?
  costOfStayingJson        Json?
  contractTimingRiskJson   Json?
  licensingTrapsJson       Json?
  missingEvidenceJson      Json?
  assumptionsJson          Json?
  pricingSnapshotRefsJson  Json?
  executiveRecommendation  String?
  generatedAt              DateTime?
  createdAt                DateTime                          @default(now())
  updatedAt                DateTime                          @updatedAt
  assessment               Assessment                        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
  @@index([mode])
  @@index([generatedAt])
}

model AssessmentClientContext {
  id                String                            @id @default(cuid())
  assessmentId      String                            @unique
  rawText           String?                           @db.Text
  wordCount         Int                               @default(0)
  characterCount    Int                               @default(0)
  status            AssessmentClientContextStatus     @default(not_provided)
  sourceType        AssessmentClientContextSourceType @default(customer_free_text)
  planLimitWords    Int?
  planLimitFiles    Int?
  truncated         Boolean                           @default(false)
  submittedByUserId String?
  submittedAt       DateTime?
  lastEditedAt      DateTime?
  createdAt         DateTime                          @default(now())
  updatedAt         DateTime                          @updatedAt
  assessment        Assessment                        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
  @@index([submittedAt])
  @@index([submittedByUserId])
}

model AssessmentClientContextAnalysis {
  id                        String                                @id @default(cuid())
  assessmentId              String                                @unique
  status                    AssessmentClientContextAnalysisStatus @default(not_started)
  interpretedSummary        String?                               @db.Text
  businessPrioritiesJson    Json?
  migrationConstraintsJson  Json?
  criticalWorkloadsJson     Json?
  customerReportedRisksJson Json?
  aiExtractedInsightsJson   Json?
  contradictionsJson        Json?
  validationItemsJson       Json?
  reportImpactJson          Json?
  nextQuestionsJson         Json?
  contextCompletenessScore  Int?
  businessContextConfidence String?
  analysisVersion           String?
  promptVersion             String?
  modelUsed                 String?
  safetyFlagsJson           Json?
  generatedAt               DateTime?
  createdAt                 DateTime                              @default(now())
  updatedAt                 DateTime                              @updatedAt
  assessment                Assessment                            @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
  @@index([generatedAt])
}

model AssessmentAdditionalEvidence {
  id                        String                                     @id @default(cuid())
  assessmentId              String
  evidenceFileId            String
  purpose                   AssessmentAdditionalEvidencePurpose        @default(client_context)
  classification            AssessmentAdditionalEvidenceClassification @default(unknown_needs_review)
  analysisStatus            AssessmentAdditionalEvidenceAnalysisStatus @default(received_not_analyzed)
  aiSummary                 String?                                    @db.Text
  includedInContextAnalysis Boolean                                    @default(true)
  planRestricted            Boolean                                    @default(false)
  notes                     String?                                    @db.Text
  createdAt                 DateTime                                   @default(now())
  updatedAt                 DateTime                                   @updatedAt
  assessment                Assessment                                 @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile              EvidenceFile                               @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, evidenceFileId])
  @@index([assessmentId])
  @@index([evidenceFileId])
  @@index([purpose])
  @@index([classification])
  @@index([analysisStatus])
  @@index([includedInContextAnalysis])
}

model AssessmentStorageDestinationReadiness {
  id                         String                                      @id @default(cuid())
  assessmentId               String                                      @unique
  status                     AssessmentStorageDestinationReadinessStatus @default(not_started)
  mode                       AssessmentStorageDestinationMode            @default(agnostic)
  currentStorageType         AssessmentStorageCurrentType?
  targetStoragePreference    AssessmentStorageTargetPreference?
  needsHighAvailability      Boolean?
  requiresSharedStorage      Boolean?
  hasProxmoxTarget           Boolean?
  hasPbs                     Boolean?
  hasMinimumThreeNodes       Boolean?
  hasDedicatedStorageNetwork Boolean?
  hasCephExperience          Boolean?
  hasVendorOrPartnerSupport  Boolean?
  estimatedGrowthPercent3y   Int?
  downtimeTolerance          String?
  rpoRtoNotes                String?                                     @db.Text
  sourceNotes                String?                                     @db.Text
  storageConstraintsJson     Json?
  assumptionsJson            Json?
  createdAt                  DateTime                                    @default(now())
  updatedAt                  DateTime                                    @updatedAt
  assessment                 Assessment                                  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
  @@index([mode])
  @@index([currentStorageType])
  @@index([targetStoragePreference])
}

model AssessmentStorageContext {
  id                String                         @id @default(cuid())
  assessmentId      String                         @unique
  rawText           String?                        @db.Text
  wordCount         Int                            @default(0)
  characterCount    Int                            @default(0)
  status            AssessmentStorageContextStatus @default(not_provided)
  planLimitWords    Int?
  planLimitFiles    Int?
  truncated         Boolean                        @default(false)
  submittedByUserId String?
  submittedAt       DateTime?
  lastEditedAt      DateTime?
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  assessment        Assessment                     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
  @@index([submittedAt])
  @@index([submittedByUserId])
}

model AssessmentStorageEvidence {
  id                        String                                  @id @default(cuid())
  assessmentId              String
  evidenceFileId            String
  classification            AssessmentStorageEvidenceClassification @default(unknown_needs_review)
  analysisStatus            AssessmentStorageEvidenceAnalysisStatus @default(received_not_analyzed)
  includedInStorageAnalysis Boolean                                 @default(true)
  planRestricted            Boolean                                 @default(false)
  notes                     String?                                 @db.Text
  createdAt                 DateTime                                @default(now())
  updatedAt                 DateTime                                @updatedAt
  assessment                Assessment                              @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile              EvidenceFile                            @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, evidenceFileId])
  @@index([assessmentId])
  @@index([evidenceFileId])
  @@index([classification])
  @@index([analysisStatus])
  @@index([includedInStorageAnalysis])
}

model AssessmentStorageAnalysis {
  id                        String                          @id @default(cuid())
  assessmentId              String                          @unique
  status                    AssessmentStorageAnalysisStatus @default(not_started)
  storageReadinessScore     Int?
  storageEvidenceConfidence Int?
  cephSuitabilityStatus     String?
  interpretedSummary        String?                         @db.Text
  missingEvidenceJson       Json?
  recommendationsJson       Json?
  analysisVersion           String?
  generatedAt               DateTime?
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt
  assessment                Assessment                      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([status])
  @@index([generatedAt])
}

model AssessmentAdvisorConversation {
  id              String                              @id @default(cuid())
  assessmentId    String                              @unique
  workspaceId     String
  status          AssessmentAdvisorConversationStatus @default(active)
  title           String?
  createdByUserId String?
  messageCount    Int                                 @default(0)
  creditUsed      Int                                 @default(0)
  lastMessageAt   DateTime?
  createdAt       DateTime                            @default(now())
  updatedAt       DateTime                            @updatedAt
  assessment      Assessment                          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  workspace       Workspace                           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUser   User?                               @relation("AssessmentAdvisorConversationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        AssessmentAdvisorMessage[]
  memoryItems     AssessmentAdvisorMemoryItem[]

  @@index([assessmentId])
  @@index([workspaceId])
  @@index([status])
  @@index([createdByUserId])
  @@index([lastMessageAt])
}

model AssessmentAdvisorMessage {
  id                    String                         @id @default(cuid())
  conversationId        String
  assessmentId          String
  workspaceId           String
  userId                String?
  role                  AssessmentAdvisorMessageRole
  content               String?                        @db.Text
  sanitizedContent      String                         @db.Text
  status                AssessmentAdvisorMessageStatus @default(completed)
  model                 String?
  provider              String?
  estimatedInputTokens  Int?
  estimatedOutputTokens Int?
  estimatedCostUsd      Float?
  creditCost            Int                            @default(0)
  safetyFlagsJson       Json?
  referencedContextJson Json?
  createdAt             DateTime                       @default(now())
  conversation          AssessmentAdvisorConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assessment            Assessment                     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  workspace             Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                  User?                          @relation("AssessmentAdvisorMessageUser", fields: [userId], references: [id], onDelete: SetNull)
  sourcedMemoryItems    AssessmentAdvisorMemoryItem[]  @relation("AssessmentAdvisorMemoryItemSourceMessage")

  @@index([conversationId])
  @@index([assessmentId])
  @@index([workspaceId])
  @@index([userId])
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model AssessmentAdvisorMemoryItem {
  id                String                            @id @default(cuid())
  assessmentId      String
  workspaceId       String
  conversationId    String?
  sourceMessageId   String?
  createdByUserId   String?
  type              AssessmentAdvisorMemoryItemType
  status            AssessmentAdvisorMemoryItemStatus @default(needs_review)
  sourceType        AssessmentAdvisorMemorySourceType
  truthStatus       AssessmentAdvisorMemoryTruthStatus
  title             String
  summary           String                            @db.Text
  detailsJson       Json?
  tagsJson          Json?
  relatedEntityJson Json?
  confidence        Int?
  version           Int                               @default(1)
  supersedesId      String?
  resolvedAt        DateTime?
  createdAt         DateTime                          @default(now())
  updatedAt         DateTime                          @updatedAt
  assessment        Assessment                        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  workspace         Workspace                         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation      AssessmentAdvisorConversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  sourceMessage     AssessmentAdvisorMessage?         @relation("AssessmentAdvisorMemoryItemSourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  createdByUser     User?                             @relation("AssessmentAdvisorMemoryItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  supersedes        AssessmentAdvisorMemoryItem?      @relation("AdvisorMemorySupersession", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy      AssessmentAdvisorMemoryItem[]     @relation("AdvisorMemorySupersession")

  @@index([assessmentId, status])
  @@index([workspaceId, type])
  @@index([assessmentId, type, status])
  @@index([sourceMessageId])
  @@index([supersedesId])
}

model StorageReadinessInput {
  id                             String     @id @default(cuid())
  assessmentId                   String     @unique
  currentStorageType             String?
  targetStoragePreference        String?
  capacityTb                     Float?
  usedTb                         Float?
  expectedGrowthPercent          Float?
  requiresHa                     Boolean?
  requiresSharedStorage          Boolean?
  workloadProfile                String?
  performanceSensitivity         String?
  operationalComplexityTolerance String?
  notes                          String?
  createdAt                      DateTime   @default(now())
  updatedAt                      DateTime   @updatedAt
  assessment                     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentEntitlement {
  id             String            @id @default(cuid())
  assessmentId   String
  entitlementKey EntitlementKey
  status         EntitlementStatus @default(locked)
  source         String?
  purchasedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assessment     Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, entitlementKey])
  @@index([assessmentId])
}

model EvidenceFile {
  id                        String                         @id @default(cuid())
  assessmentId              String
  workspaceId               String
  uploadedByUserId          String
  evidenceType              EvidenceType
  originalFilename          String
  storedFilename            String
  relativePath              String
  fileHash                  String
  mimeType                  String?
  sizeBytes                 Int
  processingStatus          EvidenceProcessingStatus       @default(uploaded)
  processingError           String?
  uploadedAt                DateTime                       @default(now())
  deletedAt                 DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  assessment                Assessment                     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  workspace                 Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedByUser            User                           @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  parsedVMs                 ParsedVM[]
  parsedHosts               ParsedHost[]
  parsedDatastores          ParsedDatastore[]
  parsedSnapshots           ParsedSnapshot[]
  parsedInventorySummary    ParsedInventorySummary?
  additionalEvidenceRecords AssessmentAdditionalEvidence[]
  storageEvidenceRecords    AssessmentStorageEvidence[]
  riskFindings              RiskFinding[]

  @@index([assessmentId])
  @@index([assessmentId, deletedAt, uploadedAt])
  @@index([workspaceId])
  @@index([uploadedByUserId])
  @@index([evidenceType])
  @@index([processingStatus])
  @@index([processingStatus, deletedAt])
  @@index([deletedAt])
}

model ParsedVM {
  id             String           @id @default(cuid())
  assessmentId   String
  evidenceFileId String
  vmName         String
  powerState     String?
  guestOs        String?
  cpuCount       Int?
  memoryMb       Int?
  diskCount      Int?
  provisionedGb  Float?
  usedGb         Float?
  nicCount       Int?
  toolsStatus    String?
  datastoreName  String?
  clusterName    String?
  hostName       String?
  riskLevel      ParsedRiskLevel?
  recommendation String?
  rawJson        Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assessment     Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile   EvidenceFile     @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([evidenceFileId])
  @@index([vmName])
  @@index([riskLevel])
}

model ParsedHost {
  id             String       @id @default(cuid())
  assessmentId   String
  evidenceFileId String
  hostName       String
  clusterName    String?
  cpuModel       String?
  cpuSockets     Int?
  cpuCores       Int?
  memoryGb       Float?
  version        String?
  rawJson        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assessment     Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile   EvidenceFile @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([evidenceFileId])
  @@index([hostName])
  @@index([clusterName])
}

model ParsedDatastore {
  id             String           @id @default(cuid())
  assessmentId   String
  evidenceFileId String
  datastoreName  String
  datastoreType  String?
  capacityGb     Float?
  usedGb         Float?
  freeGb         Float?
  usagePercent   Float?
  riskLevel      ParsedRiskLevel?
  rawJson        Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assessment     Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile   EvidenceFile     @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([evidenceFileId])
  @@index([datastoreName])
  @@index([riskLevel])
}

model ParsedSnapshot {
  id              String           @id @default(cuid())
  assessmentId    String
  evidenceFileId  String
  vmName          String?
  snapshotName    String?
  createdAtSource DateTime?
  ageDays         Int?
  sizeGb          Float?
  riskLevel       ParsedRiskLevel?
  rawJson         Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assessment      Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile    EvidenceFile     @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([evidenceFileId])
  @@index([vmName])
  @@index([riskLevel])
}

model ParsedInventorySummary {
  id                 String       @id @default(cuid())
  assessmentId       String
  evidenceFileId     String       @unique
  vmCount            Int          @default(0)
  hostCount          Int          @default(0)
  datastoreCount     Int          @default(0)
  snapshotCount      Int          @default(0)
  poweredOnVmCount   Int          @default(0)
  poweredOffVmCount  Int          @default(0)
  totalProvisionedGb Float?
  totalUsedGb        Float?
  largestVmGb        Float?
  oldestSnapshotDays Int?
  parsedAt           DateTime?
  parseWarningsJson  Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  assessment         Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile       EvidenceFile @relation(fields: [evidenceFileId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}

model RiskFinding {
  id             String              @id @default(cuid())
  assessmentId   String
  evidenceFileId String?
  category       RiskFindingCategory
  severity       RiskSeverity
  entityType     String?
  entityName     String?
  title          String
  description    String
  recommendation String?
  visibleInFree  Boolean             @default(true)
  requiresPlan   PlanLevel?
  source         RiskFindingSource
  metadataJson   Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  assessment     Assessment          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  evidenceFile   EvidenceFile?       @relation(fields: [evidenceFileId], references: [id], onDelete: SetNull)

  @@index([assessmentId])
  @@index([evidenceFileId])
  @@index([category])
  @@index([severity])
  @@index([source])
  @@index([visibleInFree])
}

model AssessmentScore {
  id              String        @id @default(cuid())
  assessmentId    String        @unique
  readinessScore  Int
  confidenceScore Int
  inventoryScore  Int?
  costRiskScore   Int?
  storageScore    Int?
  riskLevel       RiskSeverity?
  calculatedAt    DateTime      @default(now())
  metadataJson    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  assessment      Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AuditEvent {
  id           String      @id @default(cuid())
  userId       String?
  workspaceId  String?
  assessmentId String?
  eventType    String
  message      String
  metadataJson Json?
  createdAt    DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  assessment   Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assessmentId])
  @@index([userId])
  @@index([createdAt])
}

model AiUsageEvent {
  id                    String      @id @default(cuid())
  createdAt             DateTime    @default(now())
  assessmentId          String?
  userId                String?
  provider              String
  model                 String?
  operationType         String      @default("unknown")
  status                String
  durationMs            Int?
  inputChars            Int?
  outputChars           Int?
  estimatedInputTokens  Int?
  estimatedOutputTokens Int?
  estimatedTotalTokens  Int?
  estimatedCostUsd      Float?
  errorCategory         String?
  fallbackUsed          Boolean     @default(false)
  metadataJson          Json?
  user                  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  assessment            Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([assessmentId])
  @@index([assessmentId, createdAt])
  @@index([provider])
  @@index([provider, createdAt])
  @@index([status])
  @@index([status, createdAt])
  @@index([operationType])
}

model SystemSetting {
  id              String   @id @default(cuid())
  key             String   @unique
  valueJson       Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  @@index([updatedByUserId])
}

model LicensingPricingSnapshot {
  id               String                         @id @default(cuid())
  vendor           LicensingPricingVendor
  status           LicensingPricingSnapshotStatus @default(draft)
  currency         String                         @default("USD")
  sourceName       String
  sourceUrl        String?
  sourceType       LicensingPricingSourceType     @default(placeholder)
  lastCheckedAt    DateTime?
  effectiveDate    DateTime?
  approvedAt       DateTime?
  approvedByUserId String?
  rejectedAt       DateTime?
  rejectedByUserId String?
  rejectionReason  String?
  notesInternal    String?
  metadataJson     Json?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  items            LicensingPricingSnapshotItem[]
  changeLogs       LicensingPricingChangeLog[]

  @@index([vendor, status])
  @@index([status, updatedAt])
  @@index([lastCheckedAt])
  @@index([approvedAt])
}

model LicensingPricingSnapshotItem {
  id              String                   @id @default(cuid())
  snapshotId      String
  vendor          LicensingPricingVendor
  productName     String
  edition         String?
  sku             String?
  metric          LicensingPricingMetric
  unitPriceUsd    Decimal?                 @db.Decimal(14, 2)
  minUnits        Int?
  termMonths      Int?
  assumptionsJson Json?
  sourceNote      String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  snapshot        LicensingPricingSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([vendor])
  @@index([productName])
}

model LicensingPricingRefreshRun {
  id                         String                        @id @default(cuid())
  status                     LicensingPricingRefreshStatus @default(running)
  triggeredByUserId          String?
  startedAt                  DateTime                      @default(now())
  completedAt                DateTime?
  summary                    String?
  detailsJson                Json?
  createdDraftSnapshotsCount Int                           @default(0)
  errorsCount                Int                           @default(0)
  createdAt                  DateTime                      @default(now())

  @@index([status, createdAt])
  @@index([triggeredByUserId])
}

model LicensingPricingChangeLog {
  id                String                    @id @default(cuid())
  snapshotId        String?
  entityType        String
  entityId          String?
  action            String
  previousJson      Json?
  nextJson          Json?
  source            String
  performedByUserId String?
  createdAt         DateTime                  @default(now())
  snapshot          LicensingPricingSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)

  @@index([snapshotId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([performedByUserId])
}

model UserEntitlement {
  id                String    @id @default(cuid())
  userId            String
  planKey           String    @default("free_preview")
  status            String    @default("manual")
  source            String    @default("admin")
  startsAt          DateTime  @default(now())
  expiresAt         DateTime?
  maxAssessments    Int?
  maxPdfReports     Int?
  aiEnabled         Boolean   @default(false)
  fullReportEnabled Boolean   @default(false)
