  updatedAt         DateTime  @updatedAt
  createdByUserId   String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planKey])
  @@index([status])
  @@index([source])
  @@index([expiresAt])
}

model CommercialOpportunity {
  id              String    @id @default(cuid())
  userId          String?
  assessmentId    String?
  score           Int       @default(0)
  status          String    @default("new_lead")
  tagsJson        Json?
  nextBestAction  String?
  suggestedPlan   String?
  notesInternal   String?
  lastActivityAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  updatedByUserId String?

  @@index([userId])
  @@index([assessmentId])
  @@index([score])
  @@index([status])
  @@index([lastActivityAt])
}

model UpgradeEvent {
  id           String      @id @default(cuid())
  userId       String?
  workspaceId  String?
  assessmentId String?
  triggerType  String
  message      String
  clicked      Boolean     @default(false)
  createdAt    DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  assessment   Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assessmentId])
  @@index([userId])
}

model Report {
  id                String       @id @default(cuid())
  assessmentId      String
  workspaceId       String
  generatedByUserId String?
  reportType        ReportType
  status            ReportStatus
  originalFilename  String
  storedFilename    String
  relativePath      String
  fileHash          String?
  mimeType          String       @default("application/pdf")
  sizeBytes         Int?
  planRequired      PlanLevel?
  generatedAt       DateTime?
  deletedAt         DateTime?
  processingError   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  assessment        Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  workspace         Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  generatedByUser   User?        @relation(fields: [generatedByUserId], references: [id], onDelete: SetNull)

  @@index([assessmentId])
  @@index([assessmentId, deletedAt, createdAt])
  @@index([workspaceId])
  @@index([generatedByUserId])
  @@index([reportType])
  @@index([status])
  @@index([status, deletedAt])
  @@index([deletedAt])
}

model UnlockRequest {
  id            String              @id @default(cuid())
  assessmentId  String
  workspaceId   String
  userId        String
  requestedType UnlockRequestType
  status        UnlockRequestStatus @default(pending)
  amountCents   Int?
  currency      String              @default("USD")
  contactEmail  String?
  notes         String?
  adminNotes    String?
  approvedAt    DateTime?
  rejectedAt    DateTime?
  fulfilledAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  assessment    Assessment          @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([workspaceId])
  @@index([userId])
  @@index([requestedType])
  @@index([status])
  @@index([createdAt])
}

